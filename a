7. Sử dụng Hợp ngữ nhúng (Inline Assembly)
uint32_t read_hardware_register(void) {
    uint32_t val;
    // Nạp trực tiếp giá trị từ địa chỉ 0xFFA00000 vào biến val
    __asm volatile ("ldr %0, [%1]" : "=r" (val) : "r" (0xFFA00000));
    return val;
}

8. Ép kiểu trực tiếp lúc gọi hàm (Inline Cast / Anonymous Reference)Nếu bạn chỉ cần đọc hoặc ghi vào địa chỉ đó duy nhất một lần trong code và không muốn đặt tên biến hay tạo macro, bạn có thể ép kiểu và kích hoạt con trỏ ngay tại dòng lệnh.Ví dụ:c// Ghi giá trị 0x01 trực tiếp vào địa chỉ 0xFFA00000 mà không cần khai báo trước
*(volatile uint32_t *)0xFFA00000 = 0x01; 
